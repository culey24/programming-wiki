PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/programming_wiki
JWT_SECRET=change_this_to_a_long_random_secret
AGENT_SERVICE_URL=http://localhost:8000
# Optional: absolute path to wiki markdown (defaults to ../../content from repo root)
# CONTENT_DIR=/app/content
# Optional: path to docker CLI if `docker` is not on PATH
# DOCKER_BIN=/usr/bin/docker
# Docker Desktop: host + container paths for playground sandboxes (see docker-compose.yml)
# EXEC_SANDBOX_HOST_PATH=/absolute/path/to/repo/.run-sandbox
# EXEC_SANDBOX_CONTAINER_PATH=/run-sandbox
